---
import Layout from '../../layouts/Layout.astro';
import PortalNavbar from './PortalNavbar.jsx';
import PortalFooter from './PortalFooter.jsx';

const { tenant, slug, currentPath, title, description } = Astro.props;
const themeColor = tenant?.theme_color || '#2563eb';
const pageTitle = tenant ? `${title ? title + ' — ' : ''}${tenant.name}` : 'Mahallu Portal';
---

<Layout title={pageTitle} description={description || tenant?.about_description}>
  {tenant ? (
    <div
      class="min-h-screen flex flex-col bg-[#fafafc] dark:bg-[#050505] text-slate-900 dark:text-gray-100 font-sans relative overflow-x-hidden transition-colors duration-500"
      style={`--portal-theme: ${themeColor}`}
    >
      {/* Clean solid background */}
      <div className="fixed inset-0 pointer-events-none z-0 bg-white dark:bg-gray-950"></div>

      <PortalNavbar client:load tenant={tenant} slug={slug} currentPath={currentPath} />

      <main class="flex-1 w-full relative z-10 flex flex-col">
        <slot />
      </main>

      <PortalFooter client:load tenant={tenant} />
    </div>
  ) : (
    <div class="min-h-screen flex items-center justify-center text-center p-6 bg-[#fafafc] dark:bg-[#050505] text-slate-900 dark:text-gray-100">
      <div>
        <h1 class="text-2xl font-extrabold mb-2">Mahallu not found</h1>
        <p class="text-gray-500 dark:text-gray-400">This portal link looks incorrect or has expired. Please check the link and try again.</p>
      </div>
    </div>
  )}

  <script>
    // Persist/resolve the tenant slug across navigations that omit ?t=
    const params = new URLSearchParams(window.location.search);
    const urlSlug = params.get('t');
    if (urlSlug) {
      localStorage.setItem('portal_tenant', urlSlug);
    } else {
      const saved = localStorage.getItem('portal_tenant');
      if (saved) {
        const url = new URL(window.location.href);
        url.searchParams.set('t', saved);
        window.location.replace(url.toString());
      }
    }
  </script>
</Layout>
