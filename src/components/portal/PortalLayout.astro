---
import Layout from '../../layouts/Layout.astro';
import PortalNavbar from './PortalNavbar.jsx';
import PortalFooter from './PortalFooter.jsx';

const { tenant, slug, currentPath, title, description } = Astro.props;
const themeColor = tenant?.theme_color || '#2563eb';
const pageTitle = tenant ? `${title ? title + ' — ' : ''}${tenant.name}` : 'Mahallu Portal';
---

<Layout title={pageTitle} description={description || tenant?.about_description}>
  {tenant ? (
    <div
      class="min-h-screen flex flex-col bg-[#fafafc] dark:bg-[#050505] text-slate-900 dark:text-gray-100 font-sans relative overflow-x-hidden transition-colors duration-500"
      style={`--portal-theme: ${themeColor}`}
    >
      {/* Aurora mesh gradient background */}
      <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
        <div class="portal-aurora-1 absolute -top-[20%] -left-[10%] w-[70%] h-[70%] bg-gradient-to-br from-violet-200/40 to-blue-200/40 dark:from-violet-900/20 dark:to-blue-900/20 rounded-[100%] blur-[120px] mix-blend-multiply dark:mix-blend-lighten">
        </div>
        <div class="portal-aurora-2 absolute top-[20%] -right-[10%] w-[60%] h-[80%] bg-gradient-to-br from-cyan-200/40 to-emerald-100/40 dark:from-cyan-900/20 dark:to-emerald-900/10 rounded-[100%] blur-[130px] mix-blend-multiply dark:mix-blend-lighten">
        </div>
        <div class="portal-aurora-3 absolute -bottom-[20%] left-[20%] w-[80%] h-[60%] bg-gradient-to-tr from-rose-200/30 to-orange-100/30 dark:from-rose-900/10 dark:to-orange-900/10 rounded-[100%] blur-[140px] mix-blend-multiply dark:mix-blend-lighten">
        </div>
        <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.03] bg-[url('data:image/svg+xml;base64,')]">
        </div>
      </div>

      <PortalNavbar client:load tenant={tenant} slug={slug} currentPath={currentPath} />

      <main class="flex-1 w-full relative z-10 flex flex-col">
        <slot />
      </main>

      <PortalFooter client:load tenant={tenant} />
    </div>
  ) : (
    <div class="min-h-screen flex items-center justify-center text-center p-6 bg-[#fafafc] dark:bg-[#050505] text-slate-900 dark:text-gray-100">
      <div>
        <h1 class="text-2xl font-extrabold mb-2">Mahallu not found</h1>
        <p class="text-gray-500 dark:text-gray-400">This portal link looks incorrect or has expired. Please check the link and try again.</p>
      </div>
    </div>
  )}

  <script>
    // Persist/resolve the tenant slug across navigations that omit ?t=
    const params = new URLSearchParams(window.location.search);
    const urlSlug = params.get('t');
    if (urlSlug) {
      localStorage.setItem('portal_tenant', urlSlug);
    } else {
      const saved = localStorage.getItem('portal_tenant');
      if (saved) {
        const url = new URL(window.location.href);
        url.searchParams.set('t', saved);
        window.location.replace(url.toString());
      }
    }
  </script>
</Layout>

<style>
  @keyframes portal-aurora-1 {
    0%, 100% { transform: rotate(0deg) scale(1); }
    33% { transform: rotate(5deg) scale(1.05); }
    66% { transform: rotate(-5deg) scale(0.95); }
  }
  @keyframes portal-aurora-2 {
    0%, 100% { transform: rotate(0deg) scale(1); }
    33% { transform: rotate(-5deg) scale(0.95); }
    66% { transform: rotate(5deg) scale(1.05); }
  }
  @keyframes portal-aurora-3 {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(10deg); }
  }
  .portal-aurora-1 { animation: portal-aurora-1 20s linear infinite; }
  .portal-aurora-2 { animation: portal-aurora-2 25s linear infinite; }
  .portal-aurora-3 { animation: portal-aurora-3 30s linear infinite; }
</style>
