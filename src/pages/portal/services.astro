---
export const prerender = false;

import PortalLayout from '../../components/portal/PortalLayout.astro';
import ServicesIsland from '../../components/portal/ServicesIsland.jsx';
import { fetchTenantInfo } from '../../lib/portalApi';

const slug = Astro.url.searchParams.get('t') || '';
let tenant = null;
if (slug) {
  try {
    tenant = await fetchTenantInfo(slug);
  } catch {
    tenant = null;
  }
}
---

<PortalLayout tenant={tenant} slug={slug} currentPath={Astro.url.pathname} title="Our Services">
  {tenant && <ServicesIsland client:load tenant={tenant} slug={slug} />}
</PortalLayout>
