---
export const prerender = false;

import PortalLayout from '../../components/portal/PortalLayout.astro';
import AboutIsland from '../../components/portal/AboutIsland.jsx';
import { fetchTenantInfo } from '../../lib/portalApi';

const slug = Astro.url.searchParams.get('t') || '';
let tenant = null;
if (slug) {
  try {
    tenant = await fetchTenantInfo(slug);
  } catch {
    tenant = null;
  }
}
---

<PortalLayout tenant={tenant} slug={slug} currentPath={Astro.url.pathname} title="About Us">
  {tenant && <AboutIsland client:load tenant={tenant} />}
</PortalLayout>
